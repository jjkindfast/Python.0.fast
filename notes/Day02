### 十三、实战项目：用类封装数据处理逻辑

#### 🚀 项目目标

创建一个完整的数据分析类，支持：

1. 读取CSV/JSON
2. 数据清洗
3. 统计分析
4. 结果保存

#### 🔧 完整代码

```python
import csv
import json
from typing import List, Dict, Any

class DataAnalyzer:
    """数据分析类"""
    
    def __init__(self):
        self.data = None
        self.cleaned_data = None
    
    def load_csv(self, file_path: str) -> 'DataAnalyzer':
        """加载CSV文件"""
        with open(file_path, 'r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            self.data = list(reader)
        return self
    
    def load_json(self, file_path: str) -> 'DataAnalyzer':
        """加载JSON文件"""
        with open(file_path, 'r', encoding='utf-8') as f:
            self.data = json.load(f)
        return self
    
    def clean_data(self) -> 'DataAnalyzer':
        """清洗数据"""
        if not self.data:
            raise ValueError('请先加载数据')
        
        self.cleaned_data = []
        for row in self.data:
            cleaned_row = {}
            for key, value in row.items():
                # 尝试转换为数值
                try:
                    if '.' in str(value):
                        cleaned_row[key] = float(value)
                    else:
                        cleaned_row[key] = int(value)
                except (ValueError, TypeError):
                    cleaned_row[key] = value
            self.cleaned_data.append(cleaned_row)
        return self
    
    def get_numeric_column(self, column_name: str) -> List[float]:
        """获取数值列"""
        if not self.cleaned_data:
            raise ValueError('请先清洗数据')
        
        values = []
        for row in self.cleaned_data:
            val = row.get(column_name)
            if isinstance(val, (int, float)):
                values.append(val)
        return values
    
    def analyze_column(self, column_name: str) -> Dict[str, Any]:
        """分析单列"""
        values = self.get_numeric_column(column_name)
        if not values:
            return None
        
        sorted_values = sorted(values)
        n = len(sorted_values)
        
        return {
            'column': column_name,
            'count': n,
            'sum': sum(values),
            'mean': sum(values) / n,
            'median': sorted_values[n//2] if n%2 else (sorted_values[n//2-1] + sorted_values[n//2])/2,
            'min': min(values),
            'max': max(values)
        }
    
    def save_result(self, result: Dict[str, Any], file_path: str) -> 'DataAnalyzer':
        """保存结果"""
        with open(file_path, 'w', encoding='utf-8') as f:
            json.dump(result, f, ensure_ascii=False, indent=2)
        return self
    
    def __str__(self):
        if self.data:
            return f'DataAnalyzer({len(self.data)} 条数据)'
        return 'DataAnalyzer(空)'


# ==================== 使用示例 ====================

if __name__ == '__main__':
    # 1. 创建分析器
    analyzer = DataAnalyzer()
    
    # 2. 加载数据
    analyzer.load_csv('students.csv')
    print(analyzer)
    
    # 3. 清洗数据
    analyzer.clean_data()
    
    # 4. 分析分数列
    result = analyzer.analyze_column('score')
    print('分析结果:', result)
    
    # 5. 保存结果
    analyzer.save_result(result, 'analysis_result.json')
    print('结果已保存')
```

