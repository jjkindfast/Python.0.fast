### 九、装饰器

#### 📚 内容讲解

```python
import time
from functools import wraps

def timer(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        start = time.time()
        result = func(*args, **kwargs)
        end = time.time()
        print(f'{func.__name__} 耗时: {end - start:.4f}秒')
        return result
    return wrapper

@timer
def process_data(data):
    time.sleep(1)
    return sum(data)
```

